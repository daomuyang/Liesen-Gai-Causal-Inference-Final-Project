% Minimal NeurIPS-style conference package (2024-inspired)
% For use with article class; English-only documents.
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{neurips_2024}[2024/06/05 Minimal NeurIPS-style layout]

\RequirePackage[letterpaper, margin=1in, top=1in, bottom=1.1in]{geometry}
\RequirePackage{amsmath,amssymb}
\RequirePackage{booktabs}
\RequirePackage{graphicx}
\RequirePackage{float}
\RequirePackage{cite}
\RequirePackage[colorlinks=true,linkcolor=blue,citecolor=blue,urlcolor=blue]{hyperref}
\hypersetup{pdfborder={0 0 0}, breaklinks=true, linktoc=all}

% Compact table of contents
\RequirePackage{tocloft}
\setlength{\cftbeforesecskip}{2pt}
\setlength{\cftbeforesubsecskip}{0pt}
\setlength{\cftbeforesubsubsecskip}{0pt}
\setlength{\cftsecindent}{0em}
\setlength{\cftsubsecindent}{1.5em}
\setlength{\cftaftertoctitleskip}{0.5em}
\renewcommand{\contentsname}{Contents}

% Typography
\RequirePackage{times}
\renewcommand{\familydefault}{\rmdefault}
\setlength{\parindent}{0pt}
\setlength{\parskip}{0.5em plus 0.1em minus 0.05em}

% Section spacing (compact, conference-like)
\RequirePackage{titlesec}
\titleformat{\section}{\normalfont\large\bfseries}{\thesection}{0.5em}{}
\titleformat{\subsection}{\normalfont\normalsize\bfseries}{\thesubsection}{0.5em}{}
\titlespacing*{\section}{0pt}{1.2ex plus 0.2ex minus 0.1ex}{0.8ex plus 0.1ex}
\titlespacing*{\subsection}{0pt}{1.0ex plus 0.2ex minus 0.1ex}{0.5ex plus 0.1ex}

% Abstract environment (single-column, before twocolumn body)
\renewenvironment{abstract}{%
  \centerline{\normalfont\bfseries Abstract}\par\vspace{0.6em}%
  \small
  \begin{quote}%
  \noindent\ignorespaces}
 {\end{quote}\vspace{0.8em}}

% Title block
\newcommand{\@neurips@email}{}
\newcommand{\neuripsemail}[1]{\gdef\@neurips@email{#1}}

\renewcommand{\maketitle}{%
  \twocolumn[%
    \begin{center}
      {\LARGE\bfseries\@title\par}
      \vspace{1.2em}
      {\normalsize\@author\par}
      \ifx\@neurips@email\empty\else
        \vspace{0.4em}
        {\small\texttt{\@neurips@email}\par}
      \fi
      \vspace{0.4em}
      {\small\@date\par}
      \vspace{1.5em}
    \end{center}
  ]%
}

% Flag: call \neuripsbeginbody after abstract + TOC to start two-column body
\newcommand{\neuripsbeginbody}{\twocolumn}

\endinput
